{
  "objective": "Compare performance between monthly releases",
  "details": {
    "name": "preprod.gen3.biodatacatalyst.nhlbi.nih.gov",
    "UWSGI_PROCESSES": 1,
    "fence_autoscaler": {
      "min": 25,
      "max": 25,
      "targetCpu": 40
    },
    "nginx_rate_limit": "18r/s"
  },
  "service": "fence",
  "load_test_scenario": "presigned-url",
  "override_access_token": "test",
  "presigned_url_guids": [""],
  "indexd_record_acl": "phs001612.c1",
  "virtual_users": [
    { "duration": "1s", "target": 1 },
    { "duration": "30s", "target": 10 },
    { "duration": "30s", "target": 20 },
    { "duration": "30s", "target": 30 },
    { "duration": "30s", "target": 40 },
    { "duration": "480s", "target": 50 },
    { "duration": "60s", "target": 100 },
    { "duration": "240s", "target": 100 }
  ]
}
